# Smoke test environment variables
# Copy this file to .env.smoke and fill in the values

# API base URL for smoke tests
SMOKE_API_BASE_URL=

# Credentials for different roles
SMOKE_OWNER_USERNAME=
SMOKE_OWNER_PASSWORD=
SMOKE_ADMIN_USERNAME=
SMOKE_ADMIN_PASSWORD=
SMOKE_TEACHER_USERNAME=
SMOKE_TEACHER_PASSWORD=
SMOKE_STUDENT_USERNAME=
SMOKE_STUDENT_PASSWORD=
SMOKE_PANDA_USERNAME=
SMOKE_PANDA_PASSWORD=

# Allow mutations (CRUD operations) - set to 'true' only for QA environments
SMOKE_ALLOW_MUTATION=false